{
  "manifest_version": 3,
  "name": "ToolzBuy Extension",
  "version": "4.1.0",
  "description": "Please install the Toolzbuy Extension in a new Chrome profile to access to our services.",
  "permissions": [
    "proxy",
    "contentSettings",
    "declarativeNetRequest",
    "cookies",
    "storage",
    "scripting",
    "tabs",
    "webRequest",
    "webRequestAuthProvider",
    "alarms",
    "browsingData",
    "management"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "incognito": "spanning",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ToolzBuy Launcher",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["limiter.js"],
      "run_at": "document_start",
      "all_frames": false,
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": false
    },
    {
      "matches": [
        "https://extension.toolzbuy.com/*",
        "https://extension.accesstool.in/*",
        "https://app.toolzbuy.com/*"
      ],
      "js": ["launch-listener.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["bridge.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}