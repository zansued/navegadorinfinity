  "Sign_Up_Page":{
    "message":"<div class='container' id='sign-up-page'>\n\n<div class='sp-hero'>\n  <div id='registerPageTitle' class='pageTitle'><h1 class='container'>SharePass</h1></div>\n  <div class='sp-tagline' id='signup-label'>Share any account with people you trust.<br>No passwords needed.</div>\n</div>\n\n<div class='sp-field'>\n  <label class='sp-field-label' for='input-username'>Choose your username</label>\n  <input id='input-username' name='name' type='text' maxlength='20' class='sp-input' placeholder='e.g. john_doe' autocomplete='off'/>\n</div>\n\n<div class='sp-field'>\n  <label class='sp-field-label' for='input-email'>Email</label>\n  <input id='input-email' name='email' type='email' maxlength='40' class='sp-input' placeholder='you@email.com'/>\n</div>\n\n<div class='sp-referral-row' id='referrer-section'>\n  <button type='button' class='sp-referral-toggle' id='sp-referral-btn'>&#127873; Referred by a friend?</button>\n  <div class='sp-referral-input' id='sp-referral-field'>\n    <input id='input-referrer' type='text' maxlength='20' class='sp-input' placeholder='Their username'/>\n  </div>\n</div>\n\n<input type='checkbox' id='popup-toggle' style='display:none'/>\n<div id='popup-referrer' style='display:none'></div>\n\n<input id='checked1' type='checkbox' checked style='display:none'/>\n<input id='checked2' type='checkbox' checked style='display:none'/>\n\n<button id='sign-up-button'>Get Started</button>\n\n<div class='sp-agreement'>\n  By signing up, you agree to our <a target='_blank' href='https://sharepass.github.io/#three'>User Agreement</a> and to only share accounts with people you know and trust.<br>\n  <a target='_blank' href='https://policies.google.com/privacy'>Privacy Policy</a> &middot; <a target='_blank' href='https://policies.google.com/terms'>Terms</a>\n</div>\n\n<div class='sp-recover-link'><a href='#' id='sp-recover-btn'>Already have an SPID?</a></div>\n</div>"
  },
  "Recovery_Page":{
    "message":"<div class='container' id='recover-page'>\n\n<div class='sp-hero'>\n  <div id='recoverPageTitle' class='pageTitle'><h1 class='container'>Recover Your SPID</h1></div>\n  <div class='sp-tagline' id='recover-subtitle'>Enter the email you signed up with and we'll send you a recovery code.</div>\n  <div class='sp-recover-note'><strong>Note:</strong> Accounts registered in earlier versions of SharePass (before email was required) cannot be recovered, as we have no way to verify ownership.</div>\n</div>\n\n<div id='recover-step-email'>\n  <div class='sp-field'>\n    <label class='sp-field-label' for='recover-email'>Email</label>\n    <input id='recover-email' name='email' type='email' maxlength='40' class='sp-input' placeholder='you@email.com'/>\n  </div>\n  <button id='recover-send-btn'>Send Recovery Code</button>\n</div>\n\n<div id='recover-step-code' style='display:none'>\n  <div class='sp-field'>\n    <label class='sp-field-label' for='recover-code'>Enter 6-digit code</label>\n    <input id='recover-code' type='text' maxlength='6' class='sp-input sp-input-code' placeholder='000000' autocomplete='off'/>\n  </div>\n  <button id='recover-verify-btn'>Verify</button>\n</div>\n\n<div id='recover-step-success' style='display:none'>\n  <div class='sp-recover-success'>Welcome back!</div>\n  <p class='sp-recover-info'>Your SPID and friends have been restored. Previously shared accounts will need to be re-shared.</p>\n  <button id='recover-done-btn'>Get Started</button>\n</div>\n\n<div id='recover-error' class='sp-recover-error'></div>\n\n<div class='sp-recover-link'><a href='#' id='sp-back-to-signup'>Back to Sign Up</a></div>\n</div>"
  },
